# Copier ce fichier en .env et remplir les valeurs
# Sur Render : aller dans Environment > Add Variable (une par une)

MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/lumara
# ATTENTION : si le mot de passe contient @ -> %40 | # -> %23

JWT_SECRET=roomvera-secret-2026-changez-moi

STABILITY_API_KEY=sk-xxxxxxxxxxxxxxxx
# Obtenir sur : platform.stability.ai -> API Keys

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx
# Obtenir sur : console.groq.com -> API Keys

CLOUDINARY_CLOUD_NAME=dvsxn7bzk
# ATTENTION : mettre l'ID cloud (ex: dvsxn7bzk), PAS le nom de l'appli

CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=abcdefghijklmnopqrstuvwxyz

FRONTEND_URL=https://roomvera.vercel.app
# PAS de slash final !

NODE_ENV=production

# Optionnel (ajouter plus tard)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_STUDIO=price_xxx
